---
import { GraduationCap, MapPin, Compass, Quote } from "lucide-astro";
import { college } from "../data/college";

// NOTE: Copy below is deliberately conservative — no achievements, ranks or
// numbers are claimed. Confirm any additions with the college office.
const highlights = [
  {
    icon: GraduationCap,
    title: "Intermediate focus",
    text: "A dedicated junior college concentrating on the two-year intermediate programme.",
  },
  {
    icon: Compass,
    title: "Academic guidance",
    text: "Support in choosing and progressing through the right stream for each student.",
  },
  {
    icon: MapPin,
    title: "Accessible location",
    text: `Located in the ${college.contact.locality}, Adilabad — easy to reach for local families.`,
  },
];
---

<section id="about" class="container-px mx-auto max-w-7xl scroll-mt-24 py-16 lg:py-24">
  <div class="grid gap-12 lg:grid-cols-[0.95fr_1.05fr] lg:gap-16">
    <!-- Left: heading + logo panel -->
    <div data-reveal>
      <p class="eyebrow mb-3">About the college</p>
      <h2 class="font-display text-3xl font-extrabold text-ink-900 sm:text-4xl">
        A focused place for intermediate study in Adilabad
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-ink-500/80">
        {college.intro}
      </p>

      <figure
        class="mt-8 rounded-card border border-mist bg-surface p-6 shadow-[0_10px_30px_-18px_rgba(10,37,64,0.3)]"
      >
        <Quote size={22} class="text-lime-500" />
        <blockquote class="mt-3 font-display text-lg font-semibold leading-snug text-ink-900">
          “Our aim is simple — a disciplined, supportive environment where
          intermediate students can study with focus.”
        </blockquote>
        <figcaption class="mt-3 text-sm text-ink-500/60">
          {/* TO BE CONFIRMED: attribute to Principal / Management when verified. */}
          — Crescent Junior College
        </figcaption>
      </figure>
    </div>

    <!-- Right: highlights + image placeholder -->
    <div class="flex flex-col gap-5" data-reveal style="--reveal-delay:100ms">
      <div
        class="bg-grid relative flex min-h-[12rem] items-center justify-center overflow-hidden rounded-card border border-mist bg-brand-50"
      >
        <img
          src="/brand/logo-watermark-visible.png"
          alt="Crescent Junior College emblem"
          width="160"
          height="160"
          loading="lazy"
          class="h-32 w-32 object-contain opacity-90"
        />
        <span
          class="absolute bottom-3 right-4 text-xs font-medium text-brand-700/50"
          >Replace with a campus photo</span
        >
      </div>

      <ul class="grid gap-4 sm:grid-cols-1">
        {
          highlights.map((h) => (
            <li class="flex gap-4 rounded-card border border-mist bg-surface p-5 transition hover:border-brand-200 hover:shadow-sm">
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-brand-50 text-brand-700">
                <h.icon size={20} />
              </span>
              <div>
                <h3 class="font-display font-semibold text-ink-900">{h.title}</h3>
                <p class="mt-1 text-sm leading-relaxed text-ink-500/75">{h.text}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
