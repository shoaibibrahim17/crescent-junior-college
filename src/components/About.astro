---
import { college } from "../data/college";

// NOTE: Copy is deliberately conservative — no achievements, ranks or numbers
// are claimed. Confirm any additions with the college office.
const facts = [
  { label: "Type", value: college.type },
  { label: "Mode", value: college.coed },
  { label: "Streams", value: "BiPC · CEC · CSP" },
  { label: "Location", value: `${college.contact.locality}, Adilabad` },
];
---

<section id="about" class="section-y scroll-mt-24">
  <div class="container-px mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- Left: section intro + pull quote -->
      <div class="lg:col-span-5" data-reveal-group>
        <p class="kicker" data-reveal>About the college</p>
        <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
          An institution built around focus, not scale.
        </h2>

        <figure class="mt-8 border-l-2 border-brand-700 pl-5" data-reveal>
          <blockquote class="font-serif text-lg italic leading-relaxed text-ink-700">
            “Our aim is simple — a disciplined, supportive environment where
            intermediate students can study with focus.”
          </blockquote>
          <figcaption class="mt-3 text-xs font-semibold uppercase tracking-wider text-ink-400">
            {/* TO BE CONFIRMED: attribute to Principal / Management when verified. */}
            Crescent Junior College
          </figcaption>
        </figure>
      </div>

      <!-- Right: short body + key identity facts -->
      <div class="lg:col-span-7" data-reveal-group>
        <p class="max-w-xl text-[1.05rem] leading-relaxed text-ink-500" data-reveal>
          {college.intro}
        </p>

        <!-- Facts: editorial definition rows with hairlines -->
        <dl class="mt-8 grid grid-cols-1 sm:grid-cols-2" data-reveal>
          {
            facts.map((f) => (
              <div class="flex items-baseline justify-between gap-4 border-t border-line py-3.5 sm:odd:pr-8 sm:even:border-l sm:even:pl-8">
                <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">
                  {f.label}
                </dt>
                <dd class="text-right text-sm font-medium text-ink-900">{f.value}</dd>
              </div>
            ))
          }
        </dl>

        <a
          href="/courses"
          class="link-underline mt-7 inline-flex items-center gap-1.5 text-sm font-semibold text-ink-900"
          data-reveal
        >
          See the streams we offer →
        </a>
      </div>
    </div>
  </div>
</section>
