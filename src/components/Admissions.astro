---
import {
  Phone,
  MessageCircle,
  Check,
  Info,
  ChevronDown,
  BookOpen,
  Navigation,
  ClipboardList,
} from "lucide-astro";
import { college } from "../data/college";

export interface Props {
  /** "compact" = homepage (CTA tiles + collapsed details). "full" = dedicated page. */
  mode?: "compact" | "full";
}
const { mode = "full" } = Astro.props;
const { admissionSteps, documents, contact } = college;

// Compact homepage action tiles — the only thing shown by default.
const actions = [
  { icon: ClipboardList, label: "Admission enquiry", sub: "Talk to the office", href: `tel:${contact.phoneRaw}` },
  { icon: BookOpen, label: "Courses available", sub: "BiPC · CEC · CSP", href: "/courses" },
  { icon: MessageCircle, label: "Contact office", sub: "Message on WhatsApp", href: `https://wa.me/${contact.whatsapp}`, external: true },
  { icon: Navigation, label: "Visit / directions", sub: "Find us in Adilabad", href: contact.mapLink, external: true },
];

// Shared inner markup: process timeline + checklist (used expanded on `full`,
// and inside the accordion on `compact`).
---

{
  mode === "compact" ? (
    <section id="admissions" class="section-y scroll-mt-24 border-t border-line">
      <div class="container-px mx-auto max-w-7xl">
        <div class="grid gap-8 lg:grid-cols-12 lg:items-end" data-reveal-group>
          <div class="lg:col-span-7">
            <p class="kicker" data-reveal>Admissions</p>
            <h2 class="mt-5 max-w-lg font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
              Enquiries are open. Here’s how to begin.
            </h2>
          </div>
          <p class="text-[0.95rem] leading-relaxed text-ink-400 lg:col-span-5 lg:pb-1" data-reveal>
            Pick a quick action below, or open the full process and document
            checklist.
          </p>
        </div>

        {/* Compact action tiles */}
        <div class="mt-9 grid grid-cols-2 gap-2.5 sm:gap-3 lg:grid-cols-4" data-reveal-group>
          {actions.map((a) => (
            <a
              href={a.href}
              {...(a.external ? { target: "_blank", rel: "noopener" } : {})}
              class="group flex flex-col justify-between gap-6 rounded-card border border-line bg-surface p-4 transition hover:-translate-y-0.5 hover:border-brand-200 sm:p-5"
              data-reveal
            >
              <a.icon size={20} class="text-brand-700" />
              <span>
                <span class="block text-sm font-semibold text-ink-900 group-hover:text-brand-700">
                  {a.label}
                </span>
                <span class="mt-0.5 block text-xs text-ink-400">{a.sub}</span>
              </span>
            </a>
          ))}
        </div>

        {/* Expandable: process + checklist, collapsed by default */}
        <div class="mt-4 overflow-hidden rounded-card border border-line bg-paper-2" data-reveal>
          <button
            type="button"
            id="adm-trigger"
            class="accordion-trigger flex w-full items-center justify-between gap-4 px-5 py-4 text-left transition hover:bg-paper"
            aria-expanded="false"
            aria-controls="adm-panel"
          >
            <span>
              <span class="block text-sm font-semibold text-ink-900">
                View admission process &amp; documents
              </span>
              <span class="mt-0.5 block text-xs text-ink-400">
                4 simple steps · {documents.length} documents to keep ready
              </span>
            </span>
            <ChevronDown size={18} class="accordion-chevron shrink-0 text-ink-400" />
          </button>

          <div id="adm-panel" class="accordion-panel" data-open="false">
            <div class="accordion-inner">
              <div class="grid gap-10 border-t border-line px-5 py-6 lg:grid-cols-12 lg:gap-14">
                <ol class="lg:col-span-7">
                  {admissionSteps.map((step, i) => (
                    <li class="grid grid-cols-[auto_1fr] gap-x-5">
                      <div class="flex flex-col items-center">
                        <span class="numeral flex h-8 w-8 items-center justify-center rounded-full border border-line bg-surface text-xs text-brand-700">
                          {String(i + 1).padStart(2, "0")}
                        </span>
                        {i < admissionSteps.length - 1 && (
                          <span class="my-1 w-px flex-1 bg-line" aria-hidden="true" />
                        )}
                      </div>
                      <div class="pb-6">
                        <h3 class="font-serif text-base font-medium text-ink-900">{step.title}</h3>
                        <p class="mt-1 max-w-md text-sm leading-relaxed text-ink-400">{step.detail}</p>
                      </div>
                    </li>
                  ))}
                </ol>

                <div class="lg:col-span-5 lg:border-l lg:border-line lg:pl-12">
                  <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">
                    Documents checklist
                  </p>
                  <ul class="mt-3">
                    {documents.map((doc) => (
                      <li class="flex items-start gap-3 border-t border-line py-2.5 last:border-b">
                        <Check size={14} class="mt-1 shrink-0 text-lime-600" />
                        <span class="text-sm leading-relaxed text-ink-500">{doc}</span>
                      </li>
                    ))}
                  </ul>
                  <p class="mt-4 flex items-start gap-2 text-xs leading-relaxed text-ink-400">
                    <Info size={14} class="mt-0.5 shrink-0 text-amber-600" />
                    Final details, eligibility, dates and fees are confirmed by the
                    college office.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section id="admissions" class="section-y scroll-mt-24 border-t border-line">
      <div class="container-px mx-auto max-w-7xl">
        <div class="max-w-2xl" data-reveal-group>
          <p class="kicker" data-reveal>Admissions</p>
          <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
            A simple, transparent admission process.
          </h2>
          <p class="mt-3 leading-relaxed text-ink-400" data-reveal>
            Here is how admission typically works. The college office confirms exact
            steps, dates and fees.
          </p>
        </div>

        <div class="mt-12 grid gap-12 lg:grid-cols-12 lg:gap-16">
          <ol class="lg:col-span-7" data-reveal-group>
            {admissionSteps.map((step, i) => (
              <li class="grid grid-cols-[auto_1fr] gap-x-5 sm:gap-x-7" data-reveal>
                <div class="flex flex-col items-center">
                  <span class="numeral flex h-9 w-9 items-center justify-center rounded-full border border-line bg-surface text-sm text-brand-700">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  {i < admissionSteps.length - 1 && (
                    <span class="my-1 w-px flex-1 bg-line" aria-hidden="true" />
                  )}
                </div>
                <div class="pb-9">
                  <h3 class="font-serif text-lg font-medium text-ink-900">{step.title}</h3>
                  <p class="mt-1.5 max-w-md leading-relaxed text-ink-400">{step.detail}</p>
                </div>
              </li>
            ))}
          </ol>

          <div class="lg:col-span-5" data-reveal-group>
            <div data-reveal>
              <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">
                Documents checklist
              </p>
              <ul class="mt-4">
                {documents.map((doc) => (
                  <li class="flex items-start gap-3 border-t border-line py-3 last:border-b">
                    <Check size={15} class="mt-1 shrink-0 text-lime-600" />
                    <span class="text-[0.95rem] leading-relaxed text-ink-500">{doc}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-8 rounded-card border border-line bg-paper-2 p-6" data-reveal>
              <h3 class="font-serif text-lg font-medium text-ink-900">Ready to enquire?</h3>
              <p class="mt-1.5 text-sm leading-relaxed text-ink-400">
                Talk to the office about streams, seats and admission.
              </p>
              <div class="mt-4 flex flex-wrap gap-2.5">
                <a
                  href={`tel:${contact.phoneRaw}`}
                  class="inline-flex items-center gap-2 rounded-full bg-ink-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-ink-700"
                >
                  <Phone size={14} /> Call office
                </a>
                <a
                  href={`https://wa.me/${contact.whatsapp}`}
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded-full border border-line px-5 py-2.5 text-sm font-semibold text-ink-900 transition hover:border-ink-900"
                >
                  <MessageCircle size={14} class="text-lime-600" /> WhatsApp
                </a>
              </div>
            </div>
          </div>
        </div>

        <p class="mt-12 flex items-start gap-2.5 border-t border-line pt-5 text-sm leading-relaxed text-ink-400" data-reveal>
          <Info size={16} class="mt-0.5 shrink-0 text-amber-600" />
          <span>
            <strong class="font-semibold text-ink-700">Please note:</strong> Final admission
            details, eligibility, dates and fees should be confirmed directly with the
            Crescent Junior College office.
          </span>
        </p>
      </div>
    </section>
  )
}

{
  mode === "compact" && (
    <script>
      const trigger = document.getElementById("adm-trigger");
      const panel = document.getElementById("adm-panel");
      trigger?.addEventListener("click", () => {
        const open = panel?.getAttribute("data-open") === "true";
        panel?.setAttribute("data-open", String(!open));
        trigger.setAttribute("aria-expanded", String(!open));
      });
    </script>
  )
}
