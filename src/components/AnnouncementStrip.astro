---
import { Phone, MessageCircle, MapPin } from "lucide-astro";
import { college } from "../data/college";

const { contact } = college;
---

<div class="bg-ink-900 text-white/90">
  <div
    class="container-px mx-auto flex max-w-7xl flex-col gap-1.5 py-2 text-[0.82rem] sm:flex-row sm:items-center sm:justify-between"
  >
    <p class="flex items-center gap-2">
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-lime-400" aria-hidden="true"></span>
      <span>
        <span class="font-semibold text-white">Admission enquiries open</span>
        <span class="hidden text-white/60 sm:inline"> — for the new intermediate batch.</span>
      </span>
    </p>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-1">
      <a
        href={`tel:${contact.phoneRaw}`}
        class="inline-flex items-center gap-1.5 transition hover:text-lime-300"
      >
        <Phone size={13} /> Call
      </a>
      <a
        href={`https://wa.me/${contact.whatsapp}`}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 transition hover:text-lime-300"
      >
        <MessageCircle size={13} /> WhatsApp
      </a>
      <a
        href={contact.mapLink}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center gap-1.5 transition hover:text-lime-300"
      >
        <MapPin size={13} /> Directions
      </a>
    </div>
  </div>
</div>
