---
import { MapPin, Phone, MessageCircle, Mail, Navigation, Clock } from "lucide-astro";
import { college } from "../data/college";

const { contact } = college;

const actions = [
  { icon: Phone, label: "Call", href: `tel:${contact.phoneRaw}` },
  { icon: MessageCircle, label: "WhatsApp", href: `https://wa.me/${contact.whatsapp}`, external: true },
  { icon: Navigation, label: "Directions", href: contact.mapLink, external: true },
  { icon: Mail, label: "Email", href: `mailto:${contact.email}` },
];
---

<section id="contact" class="section-y scroll-mt-24 border-t border-line bg-paper-2">
  <div class="container-px mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- Left: address + actions -->
      <div class="lg:col-span-5" data-reveal-group>
        <p class="kicker" data-reveal>Contact</p>
        <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
          Visit or reach the college.
        </h2>
        <p class="mt-3 leading-relaxed text-ink-400" data-reveal>
          We’re in Adilabad. Call, message or drop by the office for any admission
          query. <span class="text-ink-400/80">Contact details to be confirmed.</span>
        </p>

        <dl class="mt-8" data-reveal>
          <div class="flex items-start gap-4 border-t border-line py-4">
            <dt class="text-brand-700"><MapPin size={18} /></dt>
            <dd>
              <span class="block text-xs font-semibold uppercase tracking-wider text-ink-400">Address</span>
              <address class="mt-1 not-italic leading-relaxed text-ink-900">
                {college.name}, {contact.address}, {contact.city}, {contact.state}
              </address>
            </dd>
          </div>
          <div class="flex items-start gap-4 border-t border-line py-4">
            <dt class="text-brand-700"><Phone size={18} /></dt>
            <dd>
              <span class="block text-xs font-semibold uppercase tracking-wider text-ink-400">Phone</span>
              <a href={`tel:${contact.phoneRaw}`} class="link-underline mt-1 inline-block font-medium text-ink-900">{contact.phone}</a>
            </dd>
          </div>
          <div class="flex items-start gap-4 border-t border-line py-4">
            <dt class="text-brand-700"><Mail size={18} /></dt>
            <dd>
              <span class="block text-xs font-semibold uppercase tracking-wider text-ink-400">Email</span>
              <a href={`mailto:${contact.email}`} class="link-underline mt-1 inline-block font-medium text-ink-900">{contact.email}</a>
            </dd>
          </div>
          <div class="flex items-start gap-4 border-y border-line py-4">
            <dt class="text-brand-700"><Clock size={18} /></dt>
            <dd>
              <span class="block text-xs font-semibold uppercase tracking-wider text-ink-400">Office hours</span>
              <span class="mt-1 inline-block font-medium text-ink-900">{contact.hours}</span>
            </dd>
          </div>
        </dl>

        <div class="mt-6 grid grid-cols-2 gap-2.5 sm:grid-cols-4" data-reveal>
          {
            actions.map((a) => (
              <a
                href={a.href}
                {...(a.external ? { target: "_blank", rel: "noopener" } : {})}
                class="inline-flex flex-col items-center justify-center gap-1.5 rounded-card border border-line bg-surface px-3 py-3.5 text-sm font-semibold text-ink-700 transition hover:border-ink-900 hover:text-ink-900"
              >
                <a.icon size={17} class="text-brand-700" />
                {a.label}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Right: map -->
      <div class="lg:col-span-7" data-reveal style="--reveal-delay:120ms">
        <div class="overflow-hidden rounded-card border border-line bg-surface">
          <iframe
            title={`Map showing ${college.name} location in Adilabad`}
            src={contact.mapEmbed}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            class="h-full min-h-[22rem] w-full lg:min-h-[30rem]"
          ></iframe>
        </div>
        <p class="mt-3 text-xs text-ink-400">
          Map pin reflects the verified Crescent Junior College listing in Adilabad.
        </p>
      </div>
    </div>
  </div>
</section>
