---
import { ArrowUpRight } from "lucide-astro";
import { college } from "../data/college";

const { courses } = college;

// Literal class strings per accent so Tailwind's scanner keeps them.
const accents = {
  blue: { text: "text-brand-700", bar: "bg-brand-700", dot: "bg-brand-700", soft: "bg-brand-50" },
  cyan: { text: "text-cyan-600", bar: "bg-cyan-600", dot: "bg-cyan-600", soft: "bg-cyan-50" },
  lime: { text: "text-lime-700", bar: "bg-lime-600", dot: "bg-lime-600", soft: "bg-lime-50" },
} as const;
---

<section id="courses" class="section-y scroll-mt-24 border-y border-line bg-surface">
  <div class="container-px mx-auto max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-12 lg:items-end" data-reveal-group>
      <div class="lg:col-span-8">
        <p class="kicker" data-reveal>Courses offered</p>
        <h2 class="mt-5 max-w-xl font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
          Three intermediate streams, each with a clear direction.
        </h2>
      </div>
      <p class="text-[0.95rem] leading-relaxed text-ink-400 lg:col-span-4 lg:pb-1" data-reveal>
        Pick the two-year group that fits your interests and the path you want to
        take after intermediate.
      </p>
    </div>

    <!-- Segmented tabs -->
    <div
      class="mt-10 flex flex-wrap gap-x-8 gap-y-2 border-b border-line"
      role="tablist"
      aria-label="Course streams"
      data-reveal
    >
      {
        courses.map((c, i) => (
          <button
            type="button"
            role="tab"
            id={`tab-${c.code}`}
            aria-controls={`panel-${c.code}`}
            aria-selected={i === 0 ? "true" : "false"}
            class="course-tab group relative -mb-px flex items-center gap-2 pb-3 pt-1 text-left transition"
            data-code={c.code}
            data-accent={c.accent}
          >
            <span
              class:list={[
                "tab-label font-serif text-lg font-medium transition-colors",
                i === 0 ? "text-ink-900" : "text-ink-400 group-hover:text-ink-700",
              ]}
            >
              {c.code}
            </span>
            <span class="hidden text-xs font-medium text-ink-400 sm:inline">
              {c.subjects.length} subjects
            </span>
            <span
              class:list={[
                "tab-bar absolute inset-x-0 bottom-0 h-0.5 origin-left transition-transform",
                accents[c.accent].bar,
                i === 0 ? "scale-x-100" : "scale-x-0",
              ]}
              aria-hidden="true"
            />
          </button>
        ))
      }
    </div>

    <!-- Panels -->
    <div class="mt-10">
      {
        courses.map((c, i) => (
          <div
            id={`panel-${c.code}`}
            role="tabpanel"
            aria-labelledby={`tab-${c.code}`}
            class="course-panel"
            hidden={i !== 0}
          >
            <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
              <!-- Left: identity + subjects -->
              <div class="lg:col-span-7">
                <p class={`text-xs font-semibold uppercase tracking-[0.18em] ${accents[c.accent].text}`}>
                  {c.code}
                </p>
                <h3 class="mt-3 font-serif text-2xl font-medium text-ink-900">{c.name}</h3>
                <p class="mt-3 max-w-lg leading-relaxed text-ink-400">{c.summary}</p>

                <p class="mt-8 text-xs font-semibold uppercase tracking-wider text-ink-400">
                  Subjects
                </p>
                <ul class="mt-2">
                  {c.subjects.map((s, si) => (
                    <li class="flex items-center gap-4 border-t border-line py-3 last:border-b">
                      <span class="numeral w-6 text-sm text-ink-400">
                        {String(si + 1).padStart(2, "0")}
                      </span>
                      <span class="text-[0.95rem] font-medium text-ink-900">{s}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <!-- Right: comparison-style notes -->
              <div class="lg:col-span-5 lg:border-l lg:border-line lg:pl-12">
                <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">
                  Who it suits
                </p>
                <p class="mt-2 leading-relaxed text-ink-500">{c.suitsFor}</p>

                <p class="mt-7 text-xs font-semibold uppercase tracking-wider text-ink-400">
                  Future pathways
                </p>
                <ul class="mt-3 space-y-2.5">
                  {c.pathways.map((p) => (
                    <li class="flex items-start gap-3 text-[0.95rem] leading-relaxed text-ink-500">
                      <span class={`mt-2 h-1 w-3 shrink-0 rounded-full ${accents[c.accent].dot}`} />
                      {p}
                    </li>
                  ))}
                </ul>

                <p class="mt-6 text-xs leading-relaxed text-ink-400">
                  Pathways are indicative and depend on each student’s results and
                  further entrance requirements.
                </p>
                <a
                  href="/#admissions"
                  class="link-underline mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-ink-900"
                >
                  Enquire about {c.code}
                  <ArrowUpRight size={15} class={accents[c.accent].text} />
                </a>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>(".course-tab"));
  const panels = Array.from(document.querySelectorAll<HTMLElement>(".course-panel"));

  function activate(code: string) {
    tabs.forEach((tab) => {
      const isActive = tab.dataset.code === code;
      tab.setAttribute("aria-selected", String(isActive));
      const label = tab.querySelector(".tab-label");
      const bar = tab.querySelector(".tab-bar");
      label?.classList.toggle("text-ink-900", isActive);
      label?.classList.toggle("text-ink-400", !isActive);
      label?.classList.toggle("group-hover:text-ink-700", !isActive);
      bar?.classList.toggle("scale-x-100", isActive);
      bar?.classList.toggle("scale-x-0", !isActive);
    });
    panels.forEach((p) => {
      const show = p.id === `panel-${code}`;
      p.hidden = !show;
      if (show) {
        p.classList.remove("opacity-0");
        // restart a gentle fade
        p.animate?.(
          [
            { opacity: 0, transform: "translateY(8px)" },
            { opacity: 1, transform: "none" },
          ],
          { duration: 350, easing: "cubic-bezier(0.2,0.7,0.2,1)" },
        );
      }
    });
  }

  tabs.forEach((tab) => tab.addEventListener("click", () => activate(tab.dataset.code!)));
  tabs.forEach((tab, i) =>
    tab.addEventListener("keydown", (e) => {
      if (e.key !== "ArrowRight" && e.key !== "ArrowLeft") return;
      e.preventDefault();
      const next =
        e.key === "ArrowRight" ? (i + 1) % tabs.length : (i - 1 + tabs.length) % tabs.length;
      tabs[next].focus();
      activate(tabs[next].dataset.code!);
    }),
  );
</script>
