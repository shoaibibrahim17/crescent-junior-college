---
import { Phone, MessageCircle, Linkedin } from "lucide-astro";
import { college } from "../data/college";

const { contact, nav } = college;
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-paper">
  <div class="container-px mx-auto max-w-7xl py-14 lg:py-16">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-5">
        <div class="flex items-center gap-3">
          <img
            src="/brand/logo-header.png"
            alt="Crescent Junior College logo"
            width="44"
            height="44"
            class="h-10 w-10 object-contain"
          />
          <span class="font-serif text-lg font-medium text-ink-900">Crescent Junior College</span>
        </div>
        <p class="mt-5 max-w-sm text-[0.95rem] leading-relaxed text-ink-400">
          A co-education junior college in Adilabad, Telangana, offering focused
          intermediate education across BiPC, CEC and Civics / Sociology / Public
          Administration streams.
        </p>
        <div class="mt-6 flex gap-2.5">
          <a
            href={`tel:${contact.phoneRaw}`}
            class="inline-flex items-center gap-1.5 rounded-full bg-ink-900 px-4 py-2 text-xs font-semibold text-white transition hover:bg-ink-700"
            ><Phone size={13} /> Call</a
          >
          <a
            href={`https://wa.me/${contact.whatsapp}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-full border border-line px-4 py-2 text-xs font-semibold text-ink-900 transition hover:border-ink-900"
            ><MessageCircle size={13} class="text-lime-600" /> WhatsApp</a
          >
        </div>
      </div>

      <!-- Quick links -->
      <div class="lg:col-span-3">
        <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-400">Explore</h3>
        <ul class="mt-4 grid grid-cols-2 gap-x-6 gap-y-2.5 text-sm lg:grid-cols-1">
          {
            nav.map((link) => (
              <li>
                <a href={link.href} class="link-underline text-ink-500 transition hover:text-brand-700">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="lg:col-span-4">
        <h3 class="text-xs font-semibold uppercase tracking-[0.16em] text-ink-400">Contact</h3>
        <address class="mt-4 not-italic text-sm leading-relaxed text-ink-500">
          {contact.address},<br />
          {contact.city}, {contact.state}, {contact.country}
        </address>
        <p class="mt-3 text-sm text-ink-500">
          <a href={`tel:${contact.phoneRaw}`} class="link-underline hover:text-brand-700">{contact.phone}</a><br />
          <a href={`mailto:${contact.email}`} class="link-underline hover:text-brand-700">{contact.email}</a>
        </p>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-3 border-t border-line pt-6 text-xs text-ink-400 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {college.name}, Adilabad. All rights reserved.</p>
      <p class="flex items-center gap-1.5">
        Designed &amp; developed by a former student —
        <a
          href="https://www.linkedin.com/in/shaikh-ibrahim17"
          target="_blank"
          rel="noopener"
          class="link-underline inline-flex items-center gap-1 font-medium text-ink-500 transition hover:text-brand-700"
        >
          <Linkedin size={13} class="text-brand-700" /> Shaikh Ibrahim
        </a>
      </p>
    </div>
  </div>
</footer>
