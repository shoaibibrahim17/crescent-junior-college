---
import { Phone, Mail, MapPin, MessageCircle } from "lucide-astro";
import { college } from "../data/college";

const { contact, nav } = college;
const year = new Date().getFullYear();
---

<footer class="border-t border-mist bg-surface">
  <div class="container-px mx-auto max-w-7xl py-12 lg:py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1.3fr]">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3">
          <img
            src="/brand/logo-header.png"
            alt="Crescent Junior College logo"
            width="48"
            height="48"
            class="h-11 w-11 object-contain"
          />
          <span class="font-display text-lg font-bold text-ink-900">Crescent Junior College</span>
        </div>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-ink-500/70">
          A co-education junior college in Adilabad, Telangana, offering focused
          intermediate education across BiPC, CEC and Civics/Sociology/Public
          Administration streams.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wide text-ink-900">
          Quick links
        </h3>
        <ul class="mt-4 grid grid-cols-2 gap-x-4 gap-y-2.5 text-sm">
          {
            nav.map((link) => (
              <li>
                <a href={link.href} class="text-ink-500/70 transition hover:text-brand-700">
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-display text-sm font-bold uppercase tracking-wide text-ink-900">
          Contact
        </h3>
        <ul class="mt-4 space-y-3 text-sm text-ink-500/75">
          <li class="flex items-start gap-2.5">
            <MapPin size={16} class="mt-0.5 shrink-0 text-brand-700" />
            <span>{contact.address}, {contact.city}, {contact.state}</span>
          </li>
          <li class="flex items-center gap-2.5">
            <Phone size={16} class="shrink-0 text-brand-700" />
            <a href={`tel:${contact.phoneRaw}`} class="hover:text-brand-700">{contact.phone}</a>
          </li>
          <li class="flex items-center gap-2.5">
            <Mail size={16} class="shrink-0 text-brand-700" />
            <a href={`mailto:${contact.email}`} class="hover:text-brand-700">{contact.email}</a>
          </li>
        </ul>
        <div class="mt-4 flex gap-2">
          <a
            href={`tel:${contact.phoneRaw}`}
            class="inline-flex items-center gap-1.5 rounded-full bg-brand-700 px-4 py-2 text-xs font-semibold text-white transition hover:bg-brand-800"
            ><Phone size={13} /> Call</a
          >
          <a
            href={`https://wa.me/${contact.whatsapp}`}
            target="_blank"
            rel="noopener"
            class="inline-flex items-center gap-1.5 rounded-full bg-lime-500 px-4 py-2 text-xs font-semibold text-ink-900 transition hover:bg-lime-400"
            ><MessageCircle size={13} /> WhatsApp</a
          >
        </div>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col gap-2 border-t border-mist pt-6 text-xs text-ink-500/55 sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {college.name}, Adilabad. All rights reserved.</p>
      <p>Demo website for client proposal — content to be confirmed by the college.</p>
    </div>
  </div>
</footer>
