---
import { Image, ArrowRight, X, ZoomIn } from "lucide-astro";
import { college } from "../data/college";

export interface Props {
  limit?: number;
  showViewAll?: boolean;
  /** Heading context — home uses a section, gallery page sets its own. */
  heading?: boolean;
}

const { limit, showViewAll = false, heading = true } = Astro.props;
const items = limit ? college.gallery.slice(0, limit) : college.gallery;

// Bento span → literal Tailwind classes (scanner-safe).
const spanClass: Record<string, string> = {
  sm: "col-span-1 row-span-1",
  md: "col-span-2 row-span-1 sm:col-span-1",
  lg: "col-span-2 row-span-2",
  wide: "col-span-2 row-span-1",
  tall: "col-span-1 row-span-2",
};
---

<section id="gallery" class="container-px mx-auto max-w-7xl scroll-mt-24 py-16 lg:py-24">
  {
    heading && (
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between" data-reveal>
        <div class="max-w-xl">
          <p class="eyebrow mb-3">Gallery</p>
          <h2 class="font-display text-3xl font-extrabold text-ink-900 sm:text-4xl">
            A look around the college
          </h2>
          <p class="mt-3 text-lg leading-relaxed text-ink-500/75">
            Placeholder tiles for now — real campus photos can drop straight in.
          </p>
        </div>
        {showViewAll && (
          <a
            href="/gallery"
            class="inline-flex w-fit items-center gap-1.5 rounded-full border border-brand-200 bg-surface px-4 py-2 text-sm font-semibold text-brand-700 transition hover:border-brand-700 hover:bg-brand-50"
          >
            View gallery <ArrowRight size={15} />
          </a>
        )}
      </div>
    )
  }

  <div
    class:list={[
      "grid auto-rows-[8.5rem] grid-cols-2 gap-3 sm:auto-rows-[9.5rem] md:grid-cols-4",
      heading ? "mt-8" : "",
    ]}
  >
    {
      items.map((item, i) => (
        <button
          type="button"
          class:list={[
            "gallery-tile group relative overflow-hidden rounded-xl border border-mist bg-brand-50 text-left transition hover:shadow-[0_14px_34px_-20px_rgba(10,37,64,0.5)] focus-visible:outline-none",
            spanClass[item.span] ?? "col-span-1 row-span-1",
          ]}
          data-caption={item.caption}
          data-src={item.src}
          data-alt={item.alt}
          data-reveal
          style={`--reveal-delay:${i * 45}ms`}
        >
          {item.src ? (
            <img
              src={item.src}
              alt={item.alt}
              loading="lazy"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
            />
          ) : (
            <span class="bg-grid flex h-full w-full flex-col items-center justify-center gap-2 text-brand-700/70">
              <Image size={24} />
              <span class="px-2 text-center text-xs font-semibold">{item.caption}</span>
            </span>
          )}
          <span class="pointer-events-none absolute inset-0 flex items-end bg-gradient-to-t from-ink-900/55 via-transparent to-transparent opacity-0 transition group-hover:opacity-100">
            <span class="flex w-full items-center justify-between gap-2 p-3 text-xs font-semibold text-white">
              {item.caption}
              <ZoomIn size={15} />
            </span>
          </span>
        </button>
      ))
    }
  </div>

  <p class="mt-4 text-center text-xs text-ink-500/55" data-reveal>
    Demo placeholders — replace with authentic Crescent Junior College photos.
  </p>
</section>

<!-- Lightbox modal -->
<div
  id="lightbox"
  class="fixed inset-0 z-[90] hidden items-center justify-center bg-ink-900/80 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image preview"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute right-4 top-4 rounded-full bg-white/10 p-2 text-white transition hover:bg-white/20"
    aria-label="Close preview"
  >
    <X size={22} />
  </button>
  <figure class="max-h-full w-full max-w-3xl">
    <div
      id="lightbox-stage"
      class="bg-grid flex aspect-[4/3] items-center justify-center overflow-hidden rounded-2xl border border-white/10 bg-brand-50"
    >
      <img id="lightbox-img" src="" alt="" class="hidden h-full w-full object-contain" />
      <div id="lightbox-placeholder" class="flex flex-col items-center gap-3 text-brand-700/70">
        <Image size={40} />
        <span class="text-sm font-semibold">Campus photo coming soon</span>
      </div>
    </div>
    <figcaption id="lightbox-caption" class="mt-3 text-center text-sm font-medium text-white/90"></figcaption>
  </figure>
</div>

<script>
  const lb = document.getElementById("lightbox");
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const lbPlaceholder = document.getElementById("lightbox-placeholder");
  const lbCaption = document.getElementById("lightbox-caption");
  const closeBtn = document.getElementById("lightbox-close");

  function openLb(src: string, alt: string, caption: string) {
    if (!lb) return;
    if (lbCaption) lbCaption.textContent = caption;
    if (src && lbImg && lbPlaceholder) {
      lbImg.src = src;
      lbImg.alt = alt;
      lbImg.classList.remove("hidden");
      lbPlaceholder.classList.add("hidden");
    } else {
      lbImg?.classList.add("hidden");
      lbPlaceholder?.classList.remove("hidden");
    }
    lb.classList.remove("hidden");
    lb.classList.add("flex");
    document.body.style.overflow = "hidden";
    closeBtn?.focus();
  }
  function closeLb() {
    if (!lb) return;
    lb.classList.add("hidden");
    lb.classList.remove("flex");
    document.body.style.overflow = "";
  }

  document.querySelectorAll<HTMLButtonElement>(".gallery-tile").forEach((tile) =>
    tile.addEventListener("click", () =>
      openLb(tile.dataset.src ?? "", tile.dataset.alt ?? "", tile.dataset.caption ?? ""),
    ),
  );
  closeBtn?.addEventListener("click", closeLb);
  lb?.addEventListener("click", (e) => {
    if (e.target === lb) closeLb();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lb && !lb.classList.contains("hidden")) closeLb();
  });
</script>
