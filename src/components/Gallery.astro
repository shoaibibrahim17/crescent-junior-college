---
import { Image, X, Plus } from "lucide-astro";
import { college } from "../data/college";

export interface Props {
  limit?: number;
  showViewAll?: boolean;
  heading?: boolean;
}

const { limit, showViewAll = false, heading = true } = Astro.props;
const items = limit ? college.gallery.slice(0, limit) : college.gallery;

// Bento span → literal Tailwind classes (scanner-safe).
const spanClass: Record<string, string> = {
  sm: "col-span-1 row-span-1",
  md: "col-span-2 row-span-1 sm:col-span-1",
  lg: "col-span-2 row-span-2",
  wide: "col-span-2 row-span-1",
  tall: "col-span-1 row-span-2",
};
---

<section id="gallery" class="section-y scroll-mt-24">
  <div class="container-px mx-auto max-w-7xl">
    {
      heading && (
        <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between" data-reveal-group>
          <div class="max-w-xl">
            <p class="kicker" data-reveal>Gallery</p>
            <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
              A look around the college.
            </h2>
            <p class="mt-3 leading-relaxed text-ink-400" data-reveal>
              These tiles are reserved for authentic campus photographs — ready to
              drop straight in.
            </p>
          </div>
          {showViewAll && (
            <a
              href="/gallery"
              class="link-underline inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-ink-900"
              data-reveal
            >
              View full gallery →
            </a>
          )}
        </div>
      )
    }

    <div
      class:list={[
        "grid auto-rows-[8rem] grid-cols-2 gap-2.5 sm:auto-rows-[9.5rem] md:grid-cols-4",
        heading ? "mt-9" : "",
      ]}
    >
      {
        items.map((item, i) => (
          <button
            type="button"
            class:list={[
              "gallery-tile group relative overflow-hidden rounded-card border border-line bg-paper-2 text-left transition hover:border-brand-200 focus-visible:outline-none",
              spanClass[item.span] ?? "col-span-1 row-span-1",
            ]}
            data-caption={item.caption}
            data-src={item.src}
            data-alt={item.alt}
            data-reveal
            style={`--reveal-delay:${i * 60}ms`}
          >
            {item.src ? (
              <img
                src={item.src}
                alt={item.alt}
                loading="lazy"
                class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.04]"
              />
            ) : (
              <span class="bg-grain flex h-full w-full flex-col justify-between p-3">
                <span class="flex items-center justify-between">
                  <span class="numeral text-xs text-ink-400">
                    {String(i + 1).padStart(2, "0")}
                  </span>
                  <Image size={15} class="text-ink-400/70" />
                </span>
                <span>
                  <span class="block text-[0.78rem] font-semibold text-ink-700">{item.caption}</span>
                  <span class="mt-0.5 flex items-center gap-1 text-[0.66rem] font-medium uppercase tracking-wide text-brand-700/70">
                    <Plus size={10} /> Photo to be added
                  </span>
                </span>
              </span>
            )}
            <span class="pointer-events-none absolute inset-0 flex items-end bg-gradient-to-t from-ink-900/45 via-transparent to-transparent opacity-0 transition group-hover:opacity-100">
              <span class="p-3 text-xs font-semibold text-white">{item.caption}</span>
            </span>
          </button>
        ))
      }
    </div>

    <p class="mt-5 text-center text-xs text-ink-400" data-reveal>
      Branded placeholders — replace with authentic Crescent Junior College photographs.
    </p>
  </div>
</section>

<!-- Lightbox modal -->
<div
  id="lightbox"
  class="fixed inset-0 z-[90] hidden items-center justify-center bg-ink-900/85 p-4 backdrop-blur-sm"
  role="dialog"
  aria-modal="true"
  aria-label="Image preview"
>
  <button
    id="lightbox-close"
    type="button"
    class="absolute right-4 top-4 rounded-full border border-white/15 p-2 text-white transition hover:bg-white/10"
    aria-label="Close preview"
  >
    <X size={20} />
  </button>
  <figure class="max-h-full w-full max-w-3xl">
    <div
      id="lightbox-stage"
      class="bg-grain flex aspect-[4/3] items-center justify-center overflow-hidden rounded-card border border-white/10 bg-paper-2"
    >
      <img id="lightbox-img" src="" alt="" class="hidden h-full w-full object-contain" />
      <div id="lightbox-placeholder" class="flex flex-col items-center gap-3 text-ink-400">
        <Image size={36} />
        <span class="text-sm font-medium">Campus photo to be added</span>
      </div>
    </div>
    <figcaption id="lightbox-caption" class="mt-3 text-center text-sm font-medium text-white/85"></figcaption>
  </figure>
</div>

<script>
  const lb = document.getElementById("lightbox");
  const lbImg = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const lbPlaceholder = document.getElementById("lightbox-placeholder");
  const lbCaption = document.getElementById("lightbox-caption");
  const closeBtn = document.getElementById("lightbox-close");
  let lastFocus: HTMLElement | null = null;

  function openLb(src: string, alt: string, caption: string, trigger: HTMLElement) {
    if (!lb) return;
    lastFocus = trigger;
    if (lbCaption) lbCaption.textContent = caption;
    if (src && lbImg && lbPlaceholder) {
      lbImg.src = src;
      lbImg.alt = alt;
      lbImg.classList.remove("hidden");
      lbPlaceholder.classList.add("hidden");
    } else {
      lbImg?.classList.add("hidden");
      lbPlaceholder?.classList.remove("hidden");
    }
    lb.classList.remove("hidden");
    lb.classList.add("flex");
    document.body.style.overflow = "hidden";
    closeBtn?.focus();
  }
  function closeLb() {
    if (!lb) return;
    lb.classList.add("hidden");
    lb.classList.remove("flex");
    document.body.style.overflow = "";
    lastFocus?.focus();
  }

  document.querySelectorAll<HTMLButtonElement>(".gallery-tile").forEach((tile) =>
    tile.addEventListener("click", () =>
      openLb(tile.dataset.src ?? "", tile.dataset.alt ?? "", tile.dataset.caption ?? "", tile),
    ),
  );
  closeBtn?.addEventListener("click", closeLb);
  lb?.addEventListener("click", (e) => {
    if (e.target === lb) closeLb();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && lb && !lb.classList.contains("hidden")) closeLb();
  });
</script>
