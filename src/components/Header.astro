---
import { Menu, X, Phone } from "lucide-astro";
import { college } from "../data/college";

const { nav, contact } = college;
---

<header id="site-header" class="sticky top-0 z-50 transition-shadow duration-300">
  <div
    id="header-inner"
    class="border-b border-transparent bg-surface/85 backdrop-blur-md transition-all duration-300"
  >
    <nav
      class="container-px mx-auto flex max-w-7xl items-center justify-between gap-4 py-3"
      aria-label="Primary"
    >
      <!-- Brand -->
      <a href="/#home" class="flex items-center gap-2.5">
        <img
          src="/brand/logo-header.png"
          alt="Crescent Junior College logo"
          width="44"
          height="44"
          class="h-10 w-10 object-contain"
        />
        <span class="leading-tight">
          <span class="block font-display text-base font-bold text-ink-900 sm:text-lg"
            >Crescent Junior College</span
          >
          <span class="block text-[0.7rem] font-medium tracking-wide text-brand-700"
            >Adilabad, Telangana</span
          >
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-1 lg:flex">
        {
          nav.map((link) => (
            <li>
              <a
                href={link.href}
                class="rounded-lg px-3 py-2 text-sm font-medium text-ink-500/80 transition hover:bg-brand-50 hover:text-brand-700"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-2">
        <a
          href={`tel:${contact.phoneRaw}`}
          class="hidden items-center gap-2 rounded-full bg-brand-700 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-brand-800 sm:inline-flex"
        >
          <Phone size={15} /> Call now
        </a>

        <!-- Mobile menu toggle -->
        <button
          id="menu-toggle"
          type="button"
          class="inline-flex items-center justify-center rounded-lg p-2 text-ink-900 transition hover:bg-brand-50 lg:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Menu size={24} class="menu-open-icon" />
          <X size={24} class="menu-close-icon hidden" />
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu panel -->
  <div
    id="mobile-menu"
    class="hidden border-b border-mist bg-surface lg:hidden"
  >
    <ul class="container-px mx-auto flex max-w-7xl flex-col py-2">
      {
        nav.map((link) => (
          <li>
            <a
              href={link.href}
              class="block rounded-lg px-3 py-3 text-base font-medium text-ink-500/90 transition hover:bg-brand-50 hover:text-brand-700"
              data-mobile-link
            >
              {link.label}
            </a>
          </li>
        ))
      }
      <li class="mt-2 grid grid-cols-2 gap-2 px-1 pb-2">
        <a
          href={`tel:${contact.phoneRaw}`}
          class="rounded-lg bg-brand-700 px-4 py-2.5 text-center text-sm font-semibold text-white"
          >Call now</a
        >
        <a
          href={`https://wa.me/${contact.whatsapp}`}
          target="_blank"
          rel="noopener"
          class="rounded-lg bg-lime-500 px-4 py-2.5 text-center text-sm font-semibold text-ink-900"
          >WhatsApp</a
        >
      </li>
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const openIcon = document.querySelector(".menu-open-icon");
  const closeIcon = document.querySelector(".menu-close-icon");

  function setMenu(open: boolean) {
    if (!menu || !toggle) return;
    menu.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () => {
    setMenu(menu?.classList.contains("hidden") ?? false);
  });
  document
    .querySelectorAll("[data-mobile-link]")
    .forEach((l) => l.addEventListener("click", () => setMenu(false)));

  // Header elevation on scroll
  const inner = document.getElementById("header-inner");
  const onScroll = () => {
    if (!inner) return;
    const scrolled = window.scrollY > 8;
    inner.classList.toggle("shadow-md", scrolled);
    inner.classList.toggle("border-mist", scrolled);
    inner.classList.toggle("bg-surface/95", scrolled);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
