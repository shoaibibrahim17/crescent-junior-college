---
import { Menu, X } from "lucide-astro";
import { college } from "../data/college";

const { nav, contact } = college;
---

<header id="site-header" class="sticky top-0 z-50">
  <div
    id="header-inner"
    class="border-b border-transparent bg-paper/80 backdrop-blur-md transition-all duration-300"
  >
    <nav
      class="container-px mx-auto flex max-w-7xl items-center justify-between gap-4 py-3"
      aria-label="Primary"
    >
      <!-- Brand -->
      <a href="/#home" class="flex items-center gap-3">
        <img
          src="/brand/logo-header.png"
          alt="Crescent Junior College logo"
          width="40"
          height="40"
          class="h-9 w-9 object-contain"
        />
        <span class="leading-none">
          <span class="block font-serif text-[1.05rem] font-medium tracking-tight text-ink-900"
            >Crescent Junior College</span
          >
          <span class="mt-1 block text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-ink-400"
            >Adilabad · Telangana</span
          >
        </span>
      </a>

      <!-- Desktop nav -->
      <ul class="hidden items-center gap-7 lg:flex">
        {
          nav.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-underline text-sm font-medium text-ink-500 transition hover:text-brand-700"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-2">
        <a
          href={`tel:${contact.phoneRaw}`}
          class="hidden rounded-full border border-ink-900 px-4 py-2 text-sm font-semibold text-ink-900 transition hover:bg-ink-900 hover:text-white sm:inline-flex lg:inline-flex"
        >
          Call now
        </a>

        <button
          id="menu-toggle"
          type="button"
          class="inline-flex items-center justify-center rounded-lg p-2 text-ink-900 transition hover:bg-paper-2 lg:hidden"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <Menu size={24} class="menu-open-icon" />
          <X size={24} class="menu-close-icon hidden" />
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile menu panel -->
  <div id="mobile-menu" class="hidden border-b border-line bg-surface lg:hidden">
    <ul class="container-px mx-auto flex max-w-7xl flex-col divide-y divide-line py-1">
      {
        nav.map((link) => (
          <li>
            <a
              href={link.href}
              class="flex items-center justify-between px-1 py-3.5 text-[0.95rem] font-medium text-ink-700 transition hover:text-brand-700"
              data-mobile-link
            >
              {link.label}
              <span class="text-ink-400" aria-hidden="true">→</span>
            </a>
          </li>
        ))
      }
      <li class="grid grid-cols-2 gap-2.5 py-3">
        <a
          href={`tel:${contact.phoneRaw}`}
          class="rounded-lg bg-ink-900 px-4 py-3 text-center text-sm font-semibold text-white"
          >Call now</a
        >
        <a
          href={`https://wa.me/${contact.whatsapp}`}
          target="_blank"
          rel="noopener"
          class="rounded-lg border border-line px-4 py-3 text-center text-sm font-semibold text-brand-700"
          >WhatsApp</a
        >
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const openIcon = document.querySelector(".menu-open-icon");
  const closeIcon = document.querySelector(".menu-close-icon");

  function setMenu(open: boolean) {
    if (!menu || !toggle) return;
    menu.classList.toggle("hidden", !open);
    toggle.setAttribute("aria-expanded", String(open));
    toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    openIcon?.classList.toggle("hidden", open);
    closeIcon?.classList.toggle("hidden", !open);
  }

  toggle?.addEventListener("click", () =>
    setMenu(menu?.classList.contains("hidden") ?? false),
  );
  document
    .querySelectorAll("[data-mobile-link]")
    .forEach((l) => l.addEventListener("click", () => setMenu(false)));

  // Header elevation + hairline on scroll
  const inner = document.getElementById("header-inner");
  const onScroll = () => {
    if (!inner) return;
    const scrolled = window.scrollY > 8;
    inner.classList.toggle("border-line", scrolled);
    inner.classList.toggle("shadow-[0_1px_0_rgba(17,35,59,0.04),0_8px_24px_-16px_rgba(17,35,59,0.25)]", scrolled);
    inner.classList.toggle("bg-paper/95", scrolled);
  };
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
