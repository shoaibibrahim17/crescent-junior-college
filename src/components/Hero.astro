---
import { ArrowRight, ArrowUpRight, Phone } from "lucide-astro";
import { college, formatDate } from "../data/college";

const chips = [college.coed, "Intermediate (BiPC · CEC · CSP)", "Adilabad, Telangana"];

// Latest three notices power the static, institutional notice list.
const heroUpdates = [...college.updates]
  .sort((a, b) => {
    if (!!a.pinned !== !!b.pinned) return a.pinned ? -1 : 1;
    return b.date.localeCompare(a.date);
  })
  .slice(0, 3);
---

<section id="home" class="relative border-b border-line bg-paper">
  <div class="mx-auto grid max-w-[100rem] lg:grid-cols-2 lg:items-stretch">
    <!-- ============================================================ -->
    <!--  Campus building image — top on mobile, right half on desktop -->
    <!-- ============================================================ -->
    <div
      class="hero-band relative order-1 min-h-[56vw] overflow-hidden sm:min-h-[40vw] lg:order-2 lg:min-h-[42rem]"
      data-hero-band
    >
      <img
        src={college.heroImage}
        alt={`${college.name} campus building in Adilabad`}
        width="1920"
        height="1280"
        loading="eager"
        fetchpriority="high"
        data-hero-bg
        class="hero-bg-img absolute inset-0 h-full w-full object-cover object-[62%_center] sm:object-center"
      />
      <!-- Edge gradient: blends image into the paper panel; very light over building -->
      <div
        class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink-900/30 to-transparent lg:bg-gradient-to-l lg:from-transparent lg:via-transparent lg:to-paper"
        aria-hidden="true"
      >
      </div>
    </div>

    <!-- ============================================================ -->
    <!--  Editorial content panel — on paper, never over the building  -->
    <!-- ============================================================ -->
    <div
      class="container-px order-2 flex flex-col justify-center py-10 sm:py-12 lg:order-1 lg:py-20"
    >
      <div class="mx-auto w-full max-w-xl lg:mr-0" data-hero-stage>
        <p class="kicker" data-hero-item>Junior &amp; Intermediate College · Adilabad</p>

        <h1 class="t-hero mt-5 font-serif font-medium text-ink-900" data-hero-item>
          A focused place for
          <em class="font-normal italic text-brand-700">intermediate</em> study in Adilabad.
        </h1>

        <p class="mt-5 max-w-md text-[1rem] leading-relaxed text-ink-400" data-hero-item>
          Guided two-year streams — BiPC, CEC and Civics / Sociology / Public
          Administration — in a calm, disciplined environment.
        </p>

        <!-- CTAs: one solid, one editorial text link -->
        <div class="mt-7 flex flex-wrap items-center gap-x-6 gap-y-3" data-hero-item>
          <a
            href="/#admissions"
            class="group inline-flex items-center gap-2 rounded-full bg-brand-700 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-brand-800"
          >
            Admission enquiry
            <ArrowRight size={15} class="transition-transform group-hover:translate-x-0.5" />
          </a>
          <a
            href="/#courses"
            class="link-underline inline-flex items-center gap-1.5 text-sm font-semibold text-ink-900"
          >
            Explore courses <ArrowUpRight size={15} class="text-brand-700" />
          </a>
        </div>

        <!-- Chips: quiet inline meta row -->
        <p
          class="mt-7 border-t border-line pt-4 text-[0.8rem] font-medium text-ink-400"
          data-hero-item
        >
          {chips.join("  ·  ")}
        </p>

        <!-- Notice + enquiry panel (clickable rows) -->
        <aside class="mt-7" data-hero-item>
      <div class="rounded-card border border-line bg-surface">
        <div class="flex items-center justify-between border-b border-line px-5 py-3.5">
          <span class="kicker kicker-center !text-ink-400">Notice board</span>
          <span
            class="rounded-full border border-line px-2.5 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wider text-ink-400"
            >Demo</span
          >
        </div>

        <ul class="divide-y divide-line">
          {
            heroUpdates.map((u) => (
              <li>
                <a
                  href="/updates"
                  class="group flex items-start gap-4 px-5 py-4 transition hover:bg-paper"
                >
                  <span class="mt-0.5 flex w-11 shrink-0 flex-col items-center rounded-md border border-line bg-paper py-1 leading-none">
                    <span class="font-serif text-base font-medium text-brand-700">
                      {formatDate(u.date).split(" ")[0]}
                    </span>
                    <span class="text-[0.6rem] font-semibold uppercase tracking-wide text-ink-400">
                      {formatDate(u.date).split(" ")[1]}
                    </span>
                  </span>
                  <span class="min-w-0">
                    <span class="flex items-center gap-2">
                      <span class="text-[0.62rem] font-semibold uppercase tracking-wider text-brand-700">
                        {u.category}
                      </span>
                      {u.pinned && (
                        <span class="h-1.5 w-1.5 rounded-full bg-lime-500" title="Pinned" />
                      )}
                    </span>
                    <span class="mt-1 block text-sm font-medium leading-snug text-ink-900 group-hover:text-brand-700">
                      {u.title}
                    </span>
                  </span>
                  <ArrowUpRight
                    size={15}
                    class="ml-auto mt-1 shrink-0 text-ink-400 opacity-0 transition group-hover:opacity-100"
                  />
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Compact enquiry strip -->
        <div class="flex items-center gap-2 border-t border-line p-3">
          <a
            href="/updates"
            class="flex-1 rounded-lg px-3 py-2.5 text-center text-sm font-semibold text-brand-700 transition hover:bg-brand-50"
          >
            All updates
          </a>
          <a
            href={`tel:${college.contact.phoneRaw}`}
            class="inline-flex flex-1 items-center justify-center gap-2 rounded-lg bg-ink-900 px-3 py-2.5 text-sm font-semibold text-white transition hover:bg-ink-700"
          >
            <Phone size={14} /> Call office
          </a>
        </div>
      </div>
        </aside>
      </div>
    </div>
  </div>
</section>

<script>
  // Staged hero entrance — fire after the splash has cleared (or immediately
  // for returning visitors / reduced motion).
  const items = Array.from(document.querySelectorAll<HTMLElement>("[data-hero-item]"));
  // `.splash-seen` is set by the head script before the splash runs, so it
  // reliably marks returning visitors (the splash sets storage after this).
  const seen = document.documentElement.classList.contains("splash-seen");
  const startDelay = seen ? 60 : 1150; // let the splash clear on first load
  const runIn = () => items.forEach((el, i) => (el.style.transitionDelay = `${i * 90}ms`, el.classList.add("is-in")));
  if (items.length) window.setTimeout(() => requestAnimationFrame(runIn), startDelay);

  // Ken-burns settle on the campus image once the band is ready.
  const band = document.querySelector<HTMLElement>("[data-hero-band]");
  window.setTimeout(() => band?.classList.add("is-in"), Math.min(startDelay, 200));

  // Very light parallax drift on the building (skipped for reduced motion).
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const bg = document.querySelector<HTMLElement>("[data-hero-bg]");
  if (bg && !reduce && window.matchMedia("(min-width: 1024px)").matches) {
    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          bg.style.transform = `scale(1) translateY(${window.scrollY * 0.05}px)`;
          ticking = false;
        });
      },
      { passive: true },
    );
  }
</script>
