---
import { ArrowRight, ArrowUpRight, Phone } from "lucide-astro";
import { college, formatDate } from "../data/college";

const chips = [college.coed, "Intermediate (BiPC · CEC · CSP)", "Adilabad, Telangana"];

// Latest three notices power the static, institutional notice list.
const heroUpdates = [...college.updates]
  .sort((a, b) => {
    if (!!a.pinned !== !!b.pinned) return a.pinned ? -1 : 1;
    return b.date.localeCompare(a.date);
  })
  .slice(0, 3);
---

<section id="home" class="relative overflow-hidden border-b border-line bg-paper">
  <!-- Subtle floating watermark -->
  <img
    src="/brand/logo-watermark-subtle.png"
    alt=""
    aria-hidden="true"
    loading="eager"
    data-parallax
    class="pointer-events-none absolute -right-24 -top-16 w-[24rem] max-w-[60%] opacity-[0.05] transition-transform duration-300 ease-out lg:w-[32rem]"
  />

  <div
    class="container-px relative mx-auto grid max-w-7xl items-center gap-y-12 py-14 sm:py-16 lg:grid-cols-12 lg:gap-x-12 lg:py-24"
  >
    <!-- Left: editorial copy -->
    <div class="lg:col-span-7" data-reveal-group>
      <p class="kicker" data-reveal>Junior &amp; Intermediate College · Est. in Adilabad</p>

      <h1
        class="mt-6 max-w-2xl font-serif text-[2.1rem] font-medium leading-[1.12] text-ink-900 sm:text-[2.7rem] lg:text-[3.15rem]"
        data-reveal
      >
        A focused place for
        <em class="font-normal italic text-brand-700">intermediate</em> study,
        rooted in Adilabad.
      </h1>

      <p class="mt-6 max-w-xl text-[1.02rem] leading-relaxed text-ink-400" data-reveal>
        Crescent Junior College offers guided two-year intermediate streams —
        BiPC, CEC and a Civics, Sociology &amp; Public Administration group — in a
        calm, disciplined environment built around steady study.
      </p>

      <!-- CTAs: one solid, one editorial text link -->
      <div class="mt-8 flex flex-wrap items-center gap-x-7 gap-y-4" data-reveal>
        <a
          href="/#admissions"
          class="group inline-flex items-center gap-2 rounded-full bg-brand-700 px-6 py-3 text-sm font-semibold text-white transition hover:bg-brand-800"
        >
          Admission enquiry
          <ArrowRight size={16} class="transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="/#courses"
          class="link-underline inline-flex items-center gap-1.5 text-sm font-semibold text-ink-900"
        >
          Explore the courses <ArrowUpRight size={15} class="text-brand-700" />
        </a>
      </div>

      <!-- Chips: inline editorial row with hairline dividers -->
      <ul
        class="mt-10 flex flex-wrap items-center gap-x-5 gap-y-2 border-t border-line pt-5 text-sm text-ink-400"
        data-reveal
      >
        {
          chips.map((chip, i) => (
            <li class="flex items-center gap-5">
              {i > 0 && <span class="hidden h-3 w-px bg-line sm:inline-block" aria-hidden="true" />}
              <span class="font-medium">{chip}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Right: editorial notice + enquiry panel (clickable rows) -->
    <aside class="lg:col-span-5" data-reveal style="--reveal-delay:140ms">
      <div class="rounded-card border border-line bg-surface">
        <div class="flex items-center justify-between border-b border-line px-5 py-3.5">
          <span class="kicker kicker-center !text-ink-400">Notice board</span>
          <span
            class="rounded-full border border-line px-2.5 py-0.5 text-[0.65rem] font-semibold uppercase tracking-wider text-ink-400"
            >Demo</span
          >
        </div>

        <ul class="divide-y divide-line">
          {
            heroUpdates.map((u) => (
              <li>
                <a
                  href="/updates"
                  class="group flex items-start gap-4 px-5 py-4 transition hover:bg-paper"
                >
                  <span class="mt-0.5 flex w-11 shrink-0 flex-col items-center rounded-md border border-line bg-paper py-1 leading-none">
                    <span class="font-serif text-base font-medium text-brand-700">
                      {formatDate(u.date).split(" ")[0]}
                    </span>
                    <span class="text-[0.6rem] font-semibold uppercase tracking-wide text-ink-400">
                      {formatDate(u.date).split(" ")[1]}
                    </span>
                  </span>
                  <span class="min-w-0">
                    <span class="flex items-center gap-2">
                      <span class="text-[0.62rem] font-semibold uppercase tracking-wider text-brand-700">
                        {u.category}
                      </span>
                      {u.pinned && (
                        <span class="h-1.5 w-1.5 rounded-full bg-lime-500" title="Pinned" />
                      )}
                    </span>
                    <span class="mt-1 block text-sm font-medium leading-snug text-ink-900 group-hover:text-brand-700">
                      {u.title}
                    </span>
                  </span>
                  <ArrowUpRight
                    size={15}
                    class="ml-auto mt-1 shrink-0 text-ink-400 opacity-0 transition group-hover:opacity-100"
                  />
                </a>
              </li>
            ))
          }
        </ul>

        <!-- Compact enquiry strip -->
        <div class="flex items-center gap-2 border-t border-line p-3">
          <a
            href="/updates"
            class="flex-1 rounded-lg px-3 py-2.5 text-center text-sm font-semibold text-brand-700 transition hover:bg-brand-50"
          >
            All updates
          </a>
          <a
            href={`tel:${college.contact.phoneRaw}`}
            class="inline-flex flex-1 items-center justify-center gap-2 rounded-lg bg-ink-900 px-3 py-2.5 text-sm font-semibold text-white transition hover:bg-ink-700"
          >
            <Phone size={14} /> Call office
          </a>
        </div>
      </div>
    </aside>
  </div>
</section>

<script>
  // Very light parallax drift on the watermark (skipped for reduced motion).
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const el = document.querySelector<HTMLElement>("[data-parallax]");
  if (el && !reduce) {
    let ticking = false;
    window.addEventListener(
      "scroll",
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          el.style.transform = `translateY(${window.scrollY * 0.06}px)`;
          ticking = false;
        });
      },
      { passive: true },
    );
  }
</script>
