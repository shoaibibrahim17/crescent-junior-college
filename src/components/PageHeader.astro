---
import { ChevronRight } from "lucide-astro";

export interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  current: string;
}

const { eyebrow, title, description, current } = Astro.props;
---

<section class="relative overflow-hidden border-b border-line bg-paper">
  <img
    src="/brand/logo-watermark-subtle.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -right-16 -top-12 w-72 opacity-[0.05]"
  />
  <div class="container-px relative mx-auto max-w-7xl py-12 lg:py-16">
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1.5 text-xs font-medium text-ink-400">
        <li><a href="/" class="link-underline transition hover:text-brand-700">Home</a></li>
        <li><ChevronRight size={13} /></li>
        <li class="text-ink-700">{current}</li>
      </ol>
    </nav>
    <p class="kicker" data-reveal>{eyebrow}</p>
    <h1 class="mt-5 max-w-3xl font-serif text-[2rem] font-medium leading-[1.12] text-ink-900 sm:text-4xl lg:text-[2.9rem]" data-reveal>
      {title}
    </h1>
    {
      description && (
        <p class="mt-5 max-w-2xl text-[1.02rem] leading-relaxed text-ink-400" data-reveal>
          {description}
        </p>
      )
    }
  </div>
</section>
