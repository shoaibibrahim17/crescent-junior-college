---
import { Home, ChevronRight } from "lucide-astro";

export interface Props {
  eyebrow: string;
  title: string;
  description?: string;
  current: string;
}

const { eyebrow, title, description, current } = Astro.props;
---

<section class="relative overflow-hidden bg-ink-900">
  <img
    src="/brand/logo-watermark-subtle.png"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute -right-12 -top-10 w-80 opacity-[0.06]"
  />
  <div
    class="bg-grid pointer-events-none absolute inset-0 opacity-30 [mask-image:radial-gradient(ellipse_at_top,black,transparent_75%)]"
  >
  </div>
  <div class="container-px relative mx-auto max-w-7xl py-12 lg:py-16">
    <nav aria-label="Breadcrumb" class="mb-4">
      <ol class="flex items-center gap-1.5 text-sm text-white/55">
        <li>
          <a href="/" class="inline-flex items-center gap-1 transition hover:text-white">
            <Home size={14} /> Home
          </a>
        </li>
        <li><ChevronRight size={14} /></li>
        <li class="font-medium text-white/90">{current}</li>
      </ol>
    </nav>
    <p class="eyebrow mb-2 text-cyan-300">{eyebrow}</p>
    <h1 class="font-display text-3xl font-extrabold text-white sm:text-4xl lg:text-5xl">
      {title}
    </h1>
    {
      description && (
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-white/70">{description}</p>
      )
    }
  </div>
</section>
