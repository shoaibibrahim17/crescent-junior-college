---
import {
  BookMarked,
  Users2,
  Clock4,
  Lightbulb,
  CalendarHeart,
  Sprout,
  ArrowLeft,
  ArrowRight,
} from "lucide-astro";

// Academic, local-feeling student-life points — no fabricated facilities.
const items = [
  { icon: BookMarked, title: "Study-first routine", text: "Timetables that keep both intermediate years on track." },
  { icon: Clock4, title: "Regular practice", text: "Steady revision and tests that build exam readiness." },
  { icon: Lightbulb, title: "Subject guidance", text: "Help with concepts across science and commerce/arts." },
  { icon: Users2, title: "A familiar setting", text: "A college where students and teachers know one another." },
  { icon: CalendarHeart, title: "Campus occasions", text: "Assemblies and college days through the year." },
  { icon: Sprout, title: "Rooted in Adilabad", text: "A local college for families across the district." },
];
---

<section class="relative overflow-hidden bg-ink-900 text-white">
  <img
    src="/brand/logo-watermark-visible.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="pointer-events-none absolute -left-20 bottom-[-3rem] w-72 opacity-[0.06]"
  />
  <div class="container-px section-y relative mx-auto max-w-7xl">
    <div class="flex items-end justify-between gap-6" data-reveal-group>
      <div class="max-w-md">
        <p class="kicker !text-cyan-400" data-reveal>Student life</p>
        <h2 class="t-h2 mt-4 font-serif font-medium text-white" data-reveal>
          A calm daily rhythm.
        </h2>
        <p class="mt-3 leading-relaxed text-white/55" data-reveal>
          Built around steady study, guidance and a familiar campus community.
        </p>
      </div>

      <div class="hidden shrink-0 gap-2 sm:flex" data-reveal>
        <button type="button" data-rail-prev class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition hover:bg-white/10 disabled:opacity-30" aria-label="Previous">
          <ArrowLeft size={17} />
        </button>
        <button type="button" data-rail-next class="flex h-10 w-10 items-center justify-center rounded-full border border-white/20 text-white transition hover:bg-white/10 disabled:opacity-30" aria-label="Next">
          <ArrowRight size={17} />
        </button>
      </div>
    </div>

    <!-- Auto-sliding horizontal rail -->
    <ul data-rail class="scroll-rail mt-8 flex gap-3 overflow-x-auto pb-2" data-reveal>
      {
        items.map((item) => (
          <li class="w-[80%] shrink-0 sm:w-[45%] lg:w-[31.5%]">
            <div class="flex h-full flex-col gap-5 rounded-card border border-white/10 bg-white/[0.03] p-5 transition hover:border-white/25 hover:bg-white/[0.06]">
              <item.icon size={20} class="text-lime-400" />
              <div>
                <h3 class="font-serif text-lg font-medium text-white">{item.title}</h3>
                <p class="mt-1.5 text-[0.88rem] leading-relaxed text-white/55">{item.text}</p>
              </div>
            </div>
          </li>
        ))
      }
    </ul>

    <!-- Dots -->
    <div class="mt-5 flex items-center gap-2 text-white" data-rail-dots aria-hidden="true">
      {items.map((_, i) => (<span class="dot" aria-selected={i === 0 ? "true" : "false"} />))}
    </div>
  </div>
</section>

<script>
  const rail = document.querySelector<HTMLElement>("[data-rail]");
  const prev = document.querySelector<HTMLButtonElement>("[data-rail-prev]");
  const next = document.querySelector<HTMLButtonElement>("[data-rail-next]");
  const dots = Array.from(document.querySelectorAll<HTMLElement>("[data-rail-dots] .dot"));
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (rail) {
    const items = Array.from(rail.children) as HTMLElement[];
    const step = () => Math.round(rail.clientWidth * 0.82);

    const update = () => {
      const max = rail.scrollWidth - rail.clientWidth - 4;
      prev?.toggleAttribute("disabled", rail.scrollLeft <= 4);
      next?.toggleAttribute("disabled", rail.scrollLeft >= max);
      // mark nearest item as active dot
      const idx = Math.round(rail.scrollLeft / (items[0]?.offsetWidth + 12 || 1));
      dots.forEach((d, i) => d.setAttribute("aria-selected", String(i === Math.min(idx, dots.length - 1))));
    };

    prev?.addEventListener("click", () => rail.scrollBy({ left: -step(), behavior: "smooth" }));
    next?.addEventListener("click", () => rail.scrollBy({ left: step(), behavior: "smooth" }));
    rail.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    update();

    // Auto-slide (one of only two auto-animated sections). Pauses on hover/focus.
    if (!reduce) {
      let timer: number | undefined;
      const tick = () => {
        const max = rail.scrollWidth - rail.clientWidth - 4;
        if (rail.scrollLeft >= max) rail.scrollTo({ left: 0, behavior: "smooth" });
        else rail.scrollBy({ left: step(), behavior: "smooth" });
      };
      const start = () => { stop(); timer = window.setInterval(tick, 3800); };
      const stop = () => timer && window.clearInterval(timer);
      const section = rail.closest("section");
      section?.addEventListener("mouseenter", stop);
      section?.addEventListener("mouseleave", start);
      section?.addEventListener("focusin", stop);
      section?.addEventListener("focusout", start);
      // Pause when off-screen to save work
      if ("IntersectionObserver" in window) {
        new IntersectionObserver(([e]) => (e.isIntersecting ? start() : stop()), { threshold: 0.2 }).observe(rail);
      } else start();
    }
  }
</script>
