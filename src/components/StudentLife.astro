---
import {
  BookMarked,
  Users2,
  Clock4,
  Lightbulb,
  CalendarHeart,
  Sprout,
} from "lucide-astro";

// Academic, local-feeling student-life points — no fabricated facilities.
const items = [
  { icon: BookMarked, title: "Study-first routine", text: "Structured timetables that keep both intermediate years on track." },
  { icon: Clock4, title: "Regular practice", text: "Steady revision and tests that build exam readiness over time." },
  { icon: Lightbulb, title: "Subject guidance", text: "Help understanding concepts across science and commerce/arts." },
  { icon: Users2, title: "A familiar setting", text: "A college where students and teachers actually know one another." },
  { icon: CalendarHeart, title: "Campus occasions", text: "Assemblies and college days that mark the academic calendar." },
  { icon: Sprout, title: "Rooted in Adilabad", text: "A local college serving students and families across the district." },
];
---

<section class="relative overflow-hidden bg-ink-900 text-white">
  <img
    src="/brand/logo-watermark-subtle.png"
    alt=""
    aria-hidden="true"
    loading="lazy"
    class="pointer-events-none absolute -left-24 bottom-[-3rem] w-80 opacity-[0.04]"
  />
  <div class="container-px section-y relative mx-auto max-w-7xl">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-16">
      <div class="lg:col-span-4">
        <p class="kicker !text-cyan-400" data-reveal>Student life</p>
        <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-white sm:text-[2rem]" data-reveal>
          A calm daily rhythm.
        </h2>
        <p class="mt-4 leading-relaxed text-white/60" data-reveal>
          Everyday life here is built around steady study, guidance and a familiar
          campus community — academic, not flashy.
        </p>
      </div>

      <ul class="grid gap-x-12 sm:grid-cols-2 lg:col-span-8" data-reveal-group>
        {
          items.map((item) => (
            <li class="flex items-start gap-4 border-t border-white/10 py-5" data-reveal>
              <item.icon size={18} class="mt-0.5 shrink-0 text-lime-400" />
              <div>
                <h3 class="font-serif text-lg font-medium text-white">{item.title}</h3>
                <p class="mt-1 text-[0.92rem] leading-relaxed text-white/55">{item.text}</p>
              </div>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
