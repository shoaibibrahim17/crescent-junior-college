---
import { Pin, ArrowUpRight, Inbox, Plus, X, Phone, CalendarDays } from "lucide-astro";
import { college, formatDate } from "../data/college";

export interface Props {
  limit?: number;
  showFilters?: boolean;
  showViewAll?: boolean;
}

const { limit, showFilters = false, showViewAll = false } = Astro.props;

const sorted = [...college.updates].sort((a, b) => {
  if (!!a.pinned !== !!b.pinned) return a.pinned ? -1 : 1;
  return b.date.localeCompare(a.date);
});
const items = limit ? sorted.slice(0, limit) : sorted;

const categories = ["All", ...Array.from(new Set(college.updates.map((u) => u.category)))];

const catColor: Record<string, string> = {
  Admissions: "text-lime-700",
  Academics: "text-brand-700",
  Events: "text-cyan-600",
  Notice: "text-amber-600",
};
---

<section id="updates" class="section-y scroll-mt-24 bg-paper-2">
  <div class="container-px mx-auto max-w-7xl">
    <div class="flex flex-col gap-5 sm:flex-row sm:items-end sm:justify-between" data-reveal-group>
      <div class="max-w-xl">
        <p class="kicker" data-reveal>Notice board</p>
        <h2 class="t-h2 mt-4 font-serif font-medium text-ink-900" data-reveal>
          Latest updates &amp; notices
        </h2>
      </div>
      {
        showViewAll && (
          <a
            href="/updates"
            class="link-underline inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-ink-900"
            data-reveal
          >
            View all updates <ArrowUpRight size={15} class="text-brand-700" />
          </a>
        )
      }
    </div>

    {
      showFilters && (
        <div class="mt-7 flex flex-wrap gap-x-6 gap-y-2 border-b border-line pb-3" role="group" aria-label="Filter updates">
          {categories.map((cat, i) => (
            <button
              type="button"
              class:list={[
                "filter-btn relative -mb-px pb-2 text-sm font-medium transition",
                i === 0 ? "text-ink-900" : "text-ink-400 hover:text-ink-700",
              ]}
              data-cat={cat}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {cat}
              <span
                class:list={[
                  "filter-bar absolute inset-x-0 bottom-0 h-0.5 origin-left bg-brand-700 transition-transform",
                  i === 0 ? "scale-x-100" : "scale-x-0",
                ]}
                aria-hidden="true"
              />
            </button>
          ))}
        </div>
      )
    }

    <!-- Compact notice rows -->
    <ul id="updates-list" class="mt-1">
      {
        items.map((u) => (
          <li
            class:list={["update-card border-t border-line last:border-b", u.pinned && "bg-surface"]}
            data-cat={u.category}
            data-reveal
          >
            <article class="flex items-center gap-3 py-3.5 sm:gap-5 sm:px-2">
              <!-- Stacked date strip -->
              <div
                class:list={[
                  "flex w-12 shrink-0 flex-col items-center rounded-md border py-1.5 leading-none sm:w-14 sm:py-2",
                  u.pinned ? "border-brand-200 bg-brand-50" : "border-line bg-paper",
                ]}
              >
                <span class="font-serif text-lg font-medium text-ink-900 sm:text-xl">
                  {formatDate(u.date).split(" ")[0]}
                </span>
                <span class="mt-0.5 text-[0.58rem] font-semibold uppercase tracking-wide text-ink-400">
                  {formatDate(u.date).split(" ")[1]}
                </span>
              </div>

              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class={`text-[0.62rem] font-semibold uppercase tracking-[0.16em] ${catColor[u.category] ?? "text-brand-700"}`}>
                    {u.category}
                  </span>
                  {u.pinned && (
                    <span class="inline-flex items-center gap-1 text-[0.6rem] font-semibold uppercase tracking-wide text-lime-700">
                      <Pin size={10} /> Pinned
                    </span>
                  )}
                </div>
                <h3 class="mt-1 truncate font-serif text-[1.02rem] font-medium text-ink-900 sm:text-lg">
                  {u.title}
                </h3>
              </div>

              <!-- Open button → modal -->
              <button
                type="button"
                class="notice-open inline-flex shrink-0 items-center gap-1.5 rounded-full border border-line bg-surface px-3.5 py-1.5 text-xs font-semibold text-ink-700 transition hover:border-brand-200 hover:text-brand-700"
                data-title={u.title}
                data-date={formatDate(u.date)}
                data-category={u.category}
                data-detail={u.detail}
                data-pinned={u.pinned ? "1" : ""}
                aria-haspopup="dialog"
              >
                <Plus size={13} /> Open
              </button>
            </article>
          </li>
        ))
      }
    </ul>

    <!-- Empty state -->
    <div
      id="updates-empty"
      class:list={[
        "mt-6 flex-col items-center justify-center rounded-card border border-dashed border-line bg-surface px-6 py-14 text-center",
        items.length === 0 ? "flex" : "hidden",
      ]}
    >
      <span class="flex h-11 w-11 items-center justify-center rounded-full border border-line text-ink-400">
        <Inbox size={20} />
      </span>
      <p class="mt-4 font-serif text-lg font-medium text-ink-900">No updates here yet</p>
      <p class="mt-1 text-sm text-ink-400">New notices appear here as the college publishes them.</p>
    </div>
  </div>
</section>

<!-- Accessible notice modal (one per page) -->
<div id="notice-modal" class="modal" role="dialog" aria-modal="true" aria-labelledby="notice-modal-title" data-open="false">
  <div class="modal__backdrop" data-close></div>
  <div class="modal__panel p-6 sm:p-7">
    <button
      type="button"
      data-close
      class="absolute right-4 top-4 rounded-full border border-line p-1.5 text-ink-400 transition hover:border-ink-900 hover:text-ink-900"
      aria-label="Close notice"
    >
      <X size={18} />
    </button>

    <span id="nm-cat" class="text-[0.66rem] font-semibold uppercase tracking-[0.18em] text-brand-700"></span>
    <h3 id="notice-modal-title" class="mt-2 max-w-[92%] font-serif text-xl font-medium leading-snug text-ink-900"></h3>
    <p class="mt-2 flex items-center gap-1.5 text-xs font-medium text-ink-400">
      <CalendarDays size={13} /> <span id="nm-date"></span>
    </p>

    <hr class="rule my-4" />
    <p id="nm-detail" class="text-[0.95rem] leading-relaxed text-ink-500"></p>

    <div class="mt-6 flex flex-wrap gap-2.5">
      <a
        href={`tel:${college.contact.phoneRaw}`}
        class="inline-flex items-center gap-2 rounded-full bg-ink-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-ink-700"
      >
        <Phone size={14} /> Call office
      </a>
      <button
        type="button"
        data-close
        class="rounded-full border border-line px-4 py-2 text-sm font-semibold text-ink-700 transition hover:border-ink-900 hover:text-ink-900"
      >
        Close
      </button>
    </div>
  </div>
</div>

<script>
  /* ---- Notice modal: accessible open/close with focus trap ---- */
  const modal = document.getElementById("notice-modal");
  const panel = modal?.querySelector<HTMLElement>(".modal__panel");
  const fTitle = document.getElementById("nm-title") || document.getElementById("notice-modal-title");
  const fCat = document.getElementById("nm-cat");
  const fDate = document.getElementById("nm-date");
  const fDetail = document.getElementById("nm-detail");
  let lastFocus: HTMLElement | null = null;

  const focusable = () =>
    Array.from(
      panel?.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ) ?? [],
    );

  function openModal(btn: HTMLElement) {
    if (!modal) return;
    lastFocus = btn;
    if (fTitle) fTitle.textContent = btn.dataset.title ?? "";
    if (fCat) fCat.textContent = btn.dataset.category ?? "";
    if (fDate) fDate.textContent = btn.dataset.date ?? "";
    if (fDetail) fDetail.textContent = btn.dataset.detail ?? "";
    modal.setAttribute("data-open", "true");
    document.body.style.overflow = "hidden";
    // wait a frame so focus lands after visibility flips
    requestAnimationFrame(() => focusable()[0]?.focus());
  }
  function closeModal() {
    if (!modal) return;
    modal.setAttribute("data-open", "false");
    document.body.style.overflow = "";
    lastFocus?.focus();
  }

  document.querySelectorAll<HTMLElement>(".notice-open").forEach((btn) =>
    btn.addEventListener("click", () => openModal(btn)),
  );
  modal?.querySelectorAll("[data-close]").forEach((el) =>
    el.addEventListener("click", closeModal),
  );
  document.addEventListener("keydown", (e) => {
    if (modal?.getAttribute("data-open") !== "true") return;
    if (e.key === "Escape") closeModal();
    if (e.key === "Tab") {
      const f = focusable();
      if (!f.length) return;
      const first = f[0];
      const last = f[f.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });
</script>

{
  showFilters && (
    <script>
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"));
      const cards = Array.from(document.querySelectorAll<HTMLElement>(".update-card"));
      const empty = document.getElementById("updates-empty");

      buttons.forEach((btn) =>
        btn.addEventListener("click", () => {
          const cat = btn.dataset.cat;
          buttons.forEach((b) => {
            const on = b === btn;
            b.setAttribute("aria-pressed", String(on));
            b.classList.toggle("text-ink-900", on);
            b.classList.toggle("text-ink-400", !on);
            b.classList.toggle("hover:text-ink-700", !on);
            b.querySelector(".filter-bar")?.classList.toggle("scale-x-100", on);
            b.querySelector(".filter-bar")?.classList.toggle("scale-x-0", !on);
          });

          let visible = 0;
          cards.forEach((card) => {
            const match = cat === "All" || card.dataset.cat === cat;
            card.classList.toggle("hidden", !match);
            if (match) {
              visible++;
              card.animate?.([{ opacity: 0 }, { opacity: 1 }], { duration: 280, easing: "ease-out" });
            }
          });
          empty?.classList.toggle("hidden", visible !== 0);
          empty?.classList.toggle("flex", visible === 0);
        }),
      );
    </script>
  )
}
