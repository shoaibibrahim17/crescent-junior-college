---
import { Pin, ArrowUpRight, Inbox } from "lucide-astro";
import { college, formatDate } from "../data/college";

export interface Props {
  limit?: number;
  showFilters?: boolean;
  showViewAll?: boolean;
}

const { limit, showFilters = false, showViewAll = false } = Astro.props;

const sorted = [...college.updates].sort((a, b) => {
  if (!!a.pinned !== !!b.pinned) return a.pinned ? -1 : 1;
  return b.date.localeCompare(a.date);
});
const items = limit ? sorted.slice(0, limit) : sorted;

const categories = ["All", ...Array.from(new Set(college.updates.map((u) => u.category)))];

const catColor: Record<string, string> = {
  Admissions: "text-lime-700",
  Academics: "text-brand-700",
  Events: "text-cyan-600",
  Notice: "text-amber-600",
};
---

<section id="updates" class="section-y scroll-mt-24 bg-paper-2">
  <div class="container-px mx-auto max-w-7xl">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between" data-reveal-group>
      <div class="max-w-xl">
        <p class="kicker" data-reveal>Notice board</p>
        <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
          Latest updates &amp; notices
        </h2>
        <p class="mt-3 leading-relaxed text-ink-400" data-reveal>
          Admission notices, academic information and announcements.
          <span class="text-ink-400/80">Demo content — maintained from the office.</span>
        </p>
      </div>
      {
        showViewAll && (
          <a
            href="/updates"
            class="link-underline inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-ink-900"
            data-reveal
          >
            View all updates <ArrowUpRight size={15} class="text-brand-700" />
          </a>
        )
      }
    </div>

    {
      showFilters && (
        <div class="mt-8 flex flex-wrap gap-x-6 gap-y-2 border-b border-line pb-3" role="group" aria-label="Filter updates">
          {categories.map((cat, i) => (
            <button
              type="button"
              class:list={[
                "filter-btn relative -mb-px pb-2 text-sm font-medium transition",
                i === 0 ? "text-ink-900" : "text-ink-400 hover:text-ink-700",
              ]}
              data-cat={cat}
              aria-pressed={i === 0 ? "true" : "false"}
            >
              {cat}
              <span
                class:list={[
                  "filter-bar absolute inset-x-0 bottom-0 h-0.5 origin-left bg-brand-700 transition-transform",
                  i === 0 ? "scale-x-100" : "scale-x-0",
                ]}
                aria-hidden="true"
              />
            </button>
          ))}
        </div>
      )
    }

    <!-- Notice rows -->
    <ul id="updates-list" class="mt-2">
      {
        items.map((u) => (
          <li
            class:list={[
              "update-card group border-t border-line last:border-b",
              u.pinned && "bg-surface",
            ]}
            data-cat={u.category}
            data-reveal
          >
            <article class="grid grid-cols-[3.25rem_1fr] items-start gap-4 py-5 sm:grid-cols-[4rem_1fr] sm:gap-6 sm:px-2">
              <!-- Stacked date strip -->
              <div
                class:list={[
                  "flex flex-col items-center rounded-md border py-2 leading-none",
                  u.pinned ? "border-brand-200 bg-brand-50" : "border-line bg-paper",
                ]}
              >
                <span class="font-serif text-xl font-medium text-ink-900">
                  {formatDate(u.date).split(" ")[0]}
                </span>
                <span class="mt-1 text-[0.6rem] font-semibold uppercase tracking-wide text-ink-400">
                  {formatDate(u.date).split(" ")[1]}
                </span>
                <span class="text-[0.6rem] text-ink-400">{formatDate(u.date).split(" ")[2]}</span>
              </div>

              <div class="min-w-0">
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                  <span class={`text-[0.66rem] font-semibold uppercase tracking-[0.16em] ${catColor[u.category] ?? "text-brand-700"}`}>
                    {u.category}
                  </span>
                  {u.pinned && (
                    <span class="inline-flex items-center gap-1 rounded-full bg-lime-500/15 px-2 py-0.5 text-[0.62rem] font-semibold uppercase tracking-wide text-lime-700">
                      <Pin size={10} /> Pinned
                    </span>
                  )}
                </div>
                <h3 class="mt-1.5 font-serif text-lg font-medium leading-snug text-ink-900">
                  {u.title}
                </h3>
                <p class="mt-1.5 max-w-2xl text-[0.95rem] leading-relaxed text-ink-400">
                  {u.detail}
                </p>
              </div>
            </article>
          </li>
        ))
      }
    </ul>

    <!-- Empty state -->
    <div
      id="updates-empty"
      class:list={[
        "mt-6 flex-col items-center justify-center rounded-card border border-dashed border-line bg-surface px-6 py-16 text-center",
        items.length === 0 ? "flex" : "hidden",
      ]}
    >
      <span class="flex h-11 w-11 items-center justify-center rounded-full border border-line text-ink-400">
        <Inbox size={20} />
      </span>
      <p class="mt-4 font-serif text-lg font-medium text-ink-900">No updates here yet</p>
      <p class="mt-1 text-sm text-ink-400">New notices appear here as the college publishes them.</p>
    </div>
  </div>
</section>

{
  showFilters && (
    <script>
      const buttons = Array.from(document.querySelectorAll<HTMLButtonElement>(".filter-btn"));
      const cards = Array.from(document.querySelectorAll<HTMLElement>(".update-card"));
      const empty = document.getElementById("updates-empty");

      buttons.forEach((btn) =>
        btn.addEventListener("click", () => {
          const cat = btn.dataset.cat;
          buttons.forEach((b) => {
            const on = b === btn;
            b.setAttribute("aria-pressed", String(on));
            b.classList.toggle("text-ink-900", on);
            b.classList.toggle("text-ink-400", !on);
            b.classList.toggle("hover:text-ink-700", !on);
            b.querySelector(".filter-bar")?.classList.toggle("scale-x-100", on);
            b.querySelector(".filter-bar")?.classList.toggle("scale-x-0", !on);
          });

          let visible = 0;
          cards.forEach((card) => {
            const match = cat === "All" || card.dataset.cat === cat;
            card.classList.toggle("hidden", !match);
            if (match) {
              visible++;
              card.animate?.(
                [{ opacity: 0 }, { opacity: 1 }],
                { duration: 280, easing: "ease-out" },
              );
            }
          });
          empty?.classList.toggle("hidden", visible !== 0);
          empty?.classList.toggle("flex", visible === 0);
        }),
      );
    </script>
  )
}
