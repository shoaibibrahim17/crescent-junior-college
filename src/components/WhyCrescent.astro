---
import { ArrowRight } from "lucide-astro";
import { college } from "../data/college";
---

<section class="section-y">
  <div class="container-px mx-auto max-w-7xl">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <!-- Left: sticky intro -->
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-28" data-reveal-group>
          <p class="kicker" data-reveal>Why Crescent</p>
          <h2 class="mt-5 font-serif text-[1.7rem] font-medium leading-tight text-ink-900 sm:text-[2rem]" data-reveal>
            What students get here.
          </h2>
          <p class="mt-4 leading-relaxed text-ink-400" data-reveal>
            Honest, practical reasons — a focused college close to home, with the
            guidance students need through their intermediate years.
          </p>
          <a
            href="/#admissions"
            class="link-underline mt-6 inline-flex items-center gap-2 text-sm font-semibold text-ink-900"
            data-reveal
          >
            Start an enquiry <ArrowRight size={15} class="text-brand-700" />
          </a>
        </div>
      </div>

      <!-- Right: numbered editorial list -->
      <ol class="lg:col-span-8" data-reveal-group>
        {
          college.whyPoints.map((point, i) => (
            <li
              class="group grid grid-cols-[auto_1fr] gap-x-6 border-t border-line py-6 last:border-b sm:gap-x-10"
              data-reveal
            >
              <span class="numeral pt-1 text-2xl text-line-soft transition-colors group-hover:text-brand-700 sm:text-3xl">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="font-serif text-lg font-medium text-ink-900 sm:text-xl">
                  {point.title}
                </h3>
                <p class="mt-2 max-w-xl leading-relaxed text-ink-400">{point.detail}</p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
