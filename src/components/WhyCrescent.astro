---
import { ArrowRight } from "lucide-astro";
import { college } from "../data/college";
---

<section class="section-y">
  <div class="container-px mx-auto max-w-7xl">
    <div class="grid gap-8 lg:grid-cols-12 lg:gap-16">
      <!-- Left: sticky intro -->
      <div class="lg:col-span-4">
        <div class="lg:sticky lg:top-28" data-reveal-group>
          <p class="kicker" data-reveal>Why Crescent</p>
          <h2 class="t-h2 mt-4 font-serif font-medium text-ink-900" data-reveal>
            What students get here.
          </h2>
          <p class="mt-3 leading-relaxed text-ink-400" data-reveal>
            Honest, practical reasons — a focused college close to home, with the
            guidance students need.
          </p>
          <a
            href="/#admissions"
            class="link-underline mt-5 inline-flex items-center gap-2 text-sm font-semibold text-ink-900"
            data-reveal
          >
            Start an enquiry <ArrowRight size={15} class="text-brand-700" />
          </a>
        </div>
      </div>

      <!-- Right: horizontal snap slider on mobile → 2-column card grid on desktop -->
      <ol
        class="scroll-rail -mx-5 mt-2 flex gap-3 overflow-x-auto px-5 pb-2 lg:mx-0 lg:col-span-8 lg:mt-0 lg:grid lg:grid-cols-2 lg:gap-4 lg:overflow-visible lg:px-0 lg:pb-0"
        data-reveal-group
      >
        {
          college.whyPoints.map((point, i) => (
            <li
              class="card-lift group grid w-[80%] shrink-0 grid-cols-[auto_1fr] gap-x-5 rounded-card border border-line bg-surface p-5 sm:w-[46%] lg:w-auto lg:gap-x-6 lg:p-6"
              data-reveal
            >
              <span class="numeral text-2xl text-line-soft transition-colors group-hover:text-brand-700">
                {String(i + 1).padStart(2, "0")}
              </span>
              <div>
                <h3 class="font-serif text-lg font-medium text-ink-900 lg:text-xl">
                  {point.title}
                </h3>
                <p class="mt-2 max-w-xl text-[0.95rem] leading-relaxed text-ink-400">
                  {point.detail}
                </p>
              </div>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
