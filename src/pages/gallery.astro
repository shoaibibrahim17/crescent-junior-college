---
import Layout from "../layouts/Layout.astro";
import AnnouncementStrip from "../components/AnnouncementStrip.astro";
import Header from "../components/Header.astro";
import PageHeader from "../components/PageHeader.astro";
import Gallery from "../components/Gallery.astro";
import Footer from "../components/Footer.astro";
import { college } from "../data/college";

const title = `Gallery | ${college.name}, Adilabad`;
const description =
  "A look around Crescent Junior College, Adilabad. Placeholder tiles ready to be replaced with authentic campus photographs.";
---

<Layout title={title} description={description} path="/gallery">
  <AnnouncementStrip />
  <Header />
  <main id="main">
    <PageHeader
      eyebrow="Gallery"
      title="Campus gallery"
      description="A visual look around the college. These are placeholder tiles — real Crescent Junior College photos can replace them directly."
      current="Gallery"
    />
    <Gallery heading={false} />
  </main>
  <Footer />
</Layout>
