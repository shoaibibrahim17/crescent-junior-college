---
import Layout from "../layouts/Layout.astro";
import AnnouncementStrip from "../components/AnnouncementStrip.astro";
import Header from "../components/Header.astro";
import PageHeader from "../components/PageHeader.astro";
import Updates from "../components/Updates.astro";
import Footer from "../components/Footer.astro";
import MobileEnquiryBar from "../components/MobileEnquiryBar.astro";
import { college } from "../data/college";

const title = `Updates & Notices | ${college.name}, Adilabad`;
const description =
  "Latest admission notices, academic information and announcements from Crescent Junior College, Adilabad.";
---

<Layout title={title} description={description} path="/updates">
  <AnnouncementStrip />
  <Header />
  <main id="main">
    <PageHeader
      eyebrow="Notice board"
      title="Updates & Notices"
      description="Admission notices, academic information and college announcements. Demo content — to be maintained by the college office."
      current="Updates"
    />
    <Updates showFilters={true} />
  </main>
  <Footer />
  <MobileEnquiryBar />
</Layout>
